# ═══════════════════════════════════════════════════════════
#   PANDUAN KONFIGURASI ENVIRONMENT
# ═══════════════════════════════════════════════════════════
#
# 1. Salin file ini:        cp .env.example .env
# 2. Isi semua nilai yang bertanda <...>
# 3. JANGAN commit file .env ke git
#
# ───────────────────────────────────────────────────────────
#   CARA MENJALANKAN APLIKASI
# ───────────────────────────────────────────────────────────
#
# MODE DEVELOPMENT (default):
#   docker compose up -d --build
#   Frontend : http://localhost:5173
#   Backend  : http://localhost:5000
#
# MODE PRODUCTION (lokal maupun server):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#   Frontend : http://localhost (port 80)
#   Backend  : http://localhost:5000
#
# ═══════════════════════════════════════════════════════════

# ── Frontend ────────────────────────────────────────────────
VITE_APP_NAME=Stresspresso

# Development:
VITE_API_BASE_URL=http://localhost:5000

# Production — pilih salah satu sesuai setup server Anda:
#
# [Opsi A] Port berbeda di server yang sama (PALING MUDAH):
# VITE_API_BASE_URL=https://stress.universitas.ac.id:5000
#
# [Opsi B] Subdomain terpisah untuk backend:
# VITE_API_BASE_URL=https://api.stress.universitas.ac.id
#
# [Opsi C] Satu domain dengan Nginx reverse proxy (path /api/):
# VITE_API_BASE_URL=https://stress.universitas.ac.id/api

# ── Database (MySQL) ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=<ganti_dengan_password_kuat>
MYSQL_DATABASE=stress_db
MYSQL_USER=<username_db>
MYSQL_PASSWORD=<password_db>

# ── Backend Flask ────────────────────────────────────────────
# Development: development | Production: production
FLASK_ENV=development
FLASK_DEBUG=1   # Set ke 0 di production

SECRET_KEY=<generate_random_string_panjang>
JWT_SECRET_KEY=<generate_random_string_panjang>
# Generate dengan: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── CORS ─────────────────────────────────────────────────────
# Daftar domain yang boleh akses API. Pisahkan dengan koma jika lebih dari satu.
# Development:
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production (ganti dengan domain frontend Anda):
# CORS_ALLOWED_ORIGINS=https://stress.universitas-anda.ac.id
# Beberapa domain:
# CORS_ALLOWED_ORIGINS=https://stress.universitas-anda.ac.id,https://www.stress.universitas-anda.ac.id
