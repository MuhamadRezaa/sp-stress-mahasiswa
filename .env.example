# ==============================================================================
# Stresspresso - Environment Configuration Template
# ==============================================================================

# --- Flask & Security ---
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=generate_using_secrets_token_hex_32
JWT_SECRET_KEY=generate_using_secrets_token_hex_32

# --- Database (MySQL) ---
# Di Lokal (Docker): MYSQL_HOST=db
# Di Lokal (Tanpa Docker): MYSQL_HOST=localhost
MYSQL_HOST=db
MYSQL_DATABASE=stress_db
MYSQL_USER=spsmdb_user
MYSQL_PASSWORD=your_secure_password
MYSQL_ROOT_PASSWORD=your_root_password

# --- Google OAuth 2.0 ---
# Ambil dari Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- Admin Seeding ---
# Digunakan saat menjalankan: python seed_admin.py
ADMIN_EMAIL=admin@domain-example.com
ADMIN_PASSWORD=your_admin_password

# --- Frontend (Vite) ---
# PERHATIAN: Variabel VITE_ akan di-bake saat build di produksi
VITE_APP_NAME=Stresspresso
VITE_API_BASE_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Networking ---
# Pisahkan dengan koma tanpa spasi
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://domain-example.com,https://domain-example.com
